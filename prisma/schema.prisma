generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Better Auth (organiser accounts)
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  organisedEvents Event[]     @relation("EventOrganiser")
  guestProfiles   EventGuest[]
  posts           Post[]
  photos          Photo[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ---------------------------------------------------------------------------
// Buxmate domain
// ---------------------------------------------------------------------------

enum EventStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum GuestStatus {
  INVITED
  JOINED
  DECLINED
}

enum RsvpStatus {
  PENDING
  GOING
  NOT_GOING
  MAYBE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  WAIVED
}

enum PostType {
  UPDATE
  ANNOUNCEMENT
  PHOTO
  PAYMENT_REMINDER
}

model Event {
  id                  String      @id @default(cuid())
  organiserId         String
  name                String
  slug                String      @unique
  eventType           String
  location            String?
  description         String?
  coverPath           String?
  status              EventStatus @default(DRAFT)
  startsAt            DateTime?
  endsAt              DateTime?
  paymentInstructions String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  organiser   User             @relation("EventOrganiser", fields: [organiserId], references: [id], onDelete: Cascade)
  guests      EventGuest[]
  activities  Activity[]
  paymentItems PaymentItem[]
  posts       Post[]
  photos      Photo[]
  inviteTokens InviteToken[]

  @@index([organiserId])
  @@index([status])
}

model EventGuest {
  id         String      @id @default(cuid())
  eventId    String
  userId     String?
  name       String
  email      String?
  phone      String?
  avatarPath String?
  status     GuestStatus @default(INVITED)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  event              Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user               User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  rsvps              ActivityRsvp[]
  paymentAllocations PaymentAllocation[]
  inviteTokens       InviteToken[]

  @@index([eventId])
  @@index([userId])
  @@index([email])
}

model Activity {
  id          String    @id @default(cuid())
  eventId     String
  title       String
  description String?
  location    String?
  startsAt    DateTime?
  endsAt      DateTime?
  costCents   Int       @default(0)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  event Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvps ActivityRsvp[]

  @@index([eventId])
}

model ActivityRsvp {
  id         String     @id @default(cuid())
  activityId String
  guestId    String
  status     RsvpStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  activity Activity   @relation(fields: [activityId], references: [id], onDelete: Cascade)
  guest    EventGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([activityId, guestId])
  @@index([guestId])
}

model PaymentItem {
  id          String   @id @default(cuid())
  eventId     String
  title       String
  description String?
  amountCents Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  allocations PaymentAllocation[]

  @@index([eventId])
}

model PaymentAllocation {
  id            String        @id @default(cuid())
  paymentItemId String
  guestId       String
  amountCents   Int
  status        PaymentStatus @default(UNPAID)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  paymentItem PaymentItem @relation(fields: [paymentItemId], references: [id], onDelete: Cascade)
  guest       EventGuest  @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([paymentItemId, guestId])
  @@index([guestId])
  @@index([status])
}

model Post {
  id            String   @id @default(cuid())
  eventId       String
  authorUserId  String?
  authorGuestId String?
  type          PostType @default(UPDATE)
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  photos Photo[]

  @@index([eventId])
  @@index([authorUserId])
}

model Photo {
  id                String   @id @default(cuid())
  eventId           String
  postId            String?
  uploadedByUserId  String?
  uploadedByGuestId String?
  storagePath       String
  caption           String?
  createdAt         DateTime @default(now())

  event          Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  post           Post?  @relation(fields: [postId], references: [id], onDelete: SetNull)
  uploadedByUser User?  @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([postId])
}

model InviteToken {
  id        String    @id @default(cuid())
  eventId   String
  guestId   String?
  token     String    @unique
  expiresAt DateTime?
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest EventGuest? @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([guestId])
}
